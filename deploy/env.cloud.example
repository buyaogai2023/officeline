# cp env.cloud.example .env 后按需修改(bootstrap-cloud.sh 会自动生成,无需手动)
# DS 与后端共享的 JWT 密钥,换成随机串
DS_JWT_SECRET=change-me-random-string
# 浏览器访问 Document Server 的地址(IP 部署用 http://公网IP:8080,域名部署改 https://$DS_DOMAIN)
DS_PUBLIC=http://1.2.3.4:8080

# --- 域名 + HTTPS(推荐;Mac App Store 版必须)---
# 在域名商(GoDaddy 等)加两条 A 记录:app 和 ds 都指向服务器公网 IP,然后取消下面注释
#APP_DOMAIN=app.yourdomain.com
#DS_DOMAIN=ds.yourdomain.com
#DS_PUBLIC=https://ds.yourdomain.com
#COMPOSE_PROFILES=https
# DeepSeek / 任意 OpenAI 兼容 API Key,留空为演示模式
AI_KEY=
# 用 Cloudflare R2/S3 对象存储时填写,并取消 compose 里对应注释
#S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
#S3_BUCKET=officeline
#S3_KEY=
#S3_SECRET=

# --- Apple 内购(Mac App Store 变现)---
# App Store Connect >「App 信息」>「App 专用共享密钥」生成
IAP_SHARED_SECRET=
# 与 App 的 Bundle ID 一致
IAP_BUNDLE_ID=com.officeline.app
# 自动续订订阅的产品 ID(逗号分隔),与 App Store Connect 里创建的一致
IAP_PRODUCTS=com.officeline.pro.monthly,com.officeline.pro.yearly
# 公网务必保持关闭(不设或非 1);设为 1 任何人可免费升级 pro,仅本地演示用
#ALLOW_DEMO_UPGRADE=1
