# Officeline HTTPS 入口(compose 的 https profile 启用)
# 两个子域各反代一个服务;证书由 Caddy 自动向 Let's Encrypt 申请并续期。
# 前提:APP_DOMAIN / DS_DOMAIN 的 DNS A 记录已指向本服务器公网 IP,且 80/443 已放行。

{$APP_DOMAIN} {
	encode gzip
	reverse_proxy app:9130
}

{$DS_DOMAIN} {
	# 访问一次即让浏览器清空本站全部缓存(品牌补丁后给老客户端用)
	handle /clear-cache {
		header Clear-Site-Data `"cache", "storage"`
		respond "cache cleared, reload the editor" 200
	}
	# 文档引擎(含 websocket,Caddy 自动透传)
	reverse_proxy ds:80
}
